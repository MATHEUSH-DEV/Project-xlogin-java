<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Logback Configuration for Kronus Rift Login System -->
    <!-- Date: 2026-03-23 -->
    <!-- Per Constitution Principle II (Security-First): -->
    <!-- - PII-safe logging (NO passwords, emails, or sensitive data) -->
    <!-- - Structured logging for audit trail -->
    <!-- - Separate audit log for compliance (90-day retention) -->

    <!-- ================================================================ -->
    <!-- PROPERTIES -->
    <!-- ================================================================ -->
    <property name="LOG_DIR" value="./logs"/>
    <property name="LOG_FILE_NAME" value="xlogin"/>
    <property name="AUDIT_LOG_FILE_NAME" value="audit-trail"/>
    <property name="MAX_FILE_SIZE" value="10MB"/>
    <property name="MAX_HISTORY" value="30"/>
    
    <!-- Structured logging pattern for SLF4J -->
    <property name="LOG_PATTERN" 
        value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
    
    <!-- JSON pattern for audit trail (machine-readable) -->
    <property name="AUDIT_PATTERN" 
        value="{&quot;timestamp&quot;:&quot;%d{yyyy-MM-dd'T'HH:mm:ss.SSS}&quot;,&quot;level&quot;:&quot;%level&quot;,&quot;thread&quot;:&quot;%thread&quot;,&quot;message&quot;:&quot;%msg&quot;}%n"/>

    <!-- ================================================================ -->
    <!-- APPENDERS: Where logs go (console, file, etc.) -->
    <!-- ================================================================ -->

    <!-- Console Appender: Real-time output to console -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File Appender: Rolling log files (daily rotation + size-based) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE_NAME}.log</file>
        
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        
        <!-- Rolling policy: rotate daily or when file hits 10MB -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_FILE_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- Keep logs for 30 days -->
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <!-- Rotate when file hits 10MB -->
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <!-- Total archived logs cap at 300MB -->
            <totalSizeCap>300MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Audit Trail Appender: Separate log for compliance audit -->
    <!-- NO PII, NO passwords, NO sensitive data -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${AUDIT_LOG_FILE_NAME}.log</file>
        
        <!-- Structured logging (JSON-like for parsing) -->
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${AUDIT_LOG_FILE_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 90-day retention per Constitution Principle II (compliance) -->
            <maxHistory>90</maxHistory>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <totalSizeCap>900MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Error File Appender: Capture only ERROR and FATAL -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE_NAME}-errors.log</file>
        
        <!-- Only log ERROR and ERROR events -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_FILE_NAME}-errors.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
        </rollingPolicy>
    </appender>

    <!-- ================================================================ -->
    <!-- LOGGERS: Map packages to appenders with specific levels -->
    <!-- ================================================================ -->

    <!-- Kronus application packages: DEBUG in dev, INFO in prod -->
    <logger name="com.kronus" level="INFO">
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Authentication & Security: ALWAYS audit via AUDIT_FILE -->
    <logger name="com.kronus.service.AuthenticationService" level="INFO">
        <appender-ref ref="AUDIT_FILE"/>
    </logger>

    <!-- Rate Limiter: ALWAYS audit -->
    <logger name="com.kronus.service.RateLimiterService" level="INFO">
        <appender-ref ref="AUDIT_FILE"/>
    </logger>

    <!-- DAO Layer: INFO (SQL queries for debugging) -->
    <logger name="com.kronus.dao" level="INFO">
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Configuration loading: DEBUG to trace config precedence -->
    <logger name="com.kronus.util.ConfigLoader" level="DEBUG">
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Third-party libraries: WARN to reduce noise -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>

    <!-- ================================================================ -->
    <!-- ROOT LOGGER: Default level for all unspecified loggers -->
    <!-- ================================================================ -->
    <root level="INFO">
        <!-- Output to console and file -->
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

    <!-- ================================================================ -->
    <!-- DEVELOPMENT-ONLY PROFILE (activated by env var DEBUG=true) -->
    <!-- ================================================================ -->
    <if condition='isDefined("DEBUG")'>
        <then>
            <!-- Increase verbosity in debug mode -->
            <logger name="com.kronus" level="DEBUG"/>
            <logger name="com.kronus.dao" level="DEBUG"/>
            <root level="DEBUG">
                <appender-ref ref="CONSOLE"/>
                <appender-ref ref="FILE"/>
            </root>
        </then>
    </if>

</configuration>
